{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "a-rewind/**/*.ts",
    "auto-trust/**/*.ts",
    "context-guard/**/*.ts",
    "grep-tool/**/*.ts",
    "model-manager/**/*.ts",
    "pi-multi-edit/**/*.ts",
    "pi-project-memory/**/*.ts",
    "pi-session-memory/**/*.ts",
    "pi-web-search/**/*.ts",
    "read-mode/**/*.ts",
    "role-sw/**/*.ts",
    "simple-gate/**/*.ts",
    "sub-agents/**/*.ts",
    "tool-dev/**/*.ts",
    "tests/**/*.ts",
    "strip-cache-retention.ts"
  ]
}
